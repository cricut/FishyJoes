{
  "name": "testapi-test",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npm run test-wasm && npm run test-native-macos",
    "test-wasm": "node --experimental-vm-modules node_modules/jest/bin/jest.js --run-in-band --detect-open-handles --force-exit --debug --no-watchman -c jest.config.wasm.cjs",
    "test-native-windows": "node --experimental-vm-modules node_modules/jest/bin/jest.js --run-in-band --detect-open-handles --force-exit --debug --no-watchman -c jest.config.native-windows.cjs",
    "test-native-macos": "node --experimental-vm-modules node_modules/jest/bin/jest.js --run-in-band --detect-open-handles --force-exit --debug --no-watchman -c jest.config.native-macos.cjs",
    "test-native-ubuntu": "node --experimental-vm-modules node_modules/jest/bin/jest.js --run-in-band --detect-open-handles --force-exit --debug --no-watchman -c jest.config.native-ubuntu.cjs",
    "clear-cache": "node node_modules/jest/bin/jest.js --clear-cache"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.18.2",
    "@types/jest": "^28.1.1",
    "jest": "^28.1.1",
    "ts-jest": "^28.0.4"
  },
  "type": "module",
  "optionalDependencies": {
    "@cricut/fishyjoes-runtime-native-windows": "file:../../../node-runtime/fishyjoes-runtime-native-windows",
    "@cricut/fishyjoes-runtime-native-macos": "file:../../../node-runtime/fishyjoes-runtime-native-macos",
    "@cricut/fishyjoes-runtime-native-ubuntu": "file:../../../node-runtime/fishyjoes-runtime-native-ubuntu",
    "@cricut/testapi-native-windows": "file:../output/node-native-windows",
    "@cricut/testapi-native-macos": "file:../output/node-native-macos",
    "@cricut/testapi-native-ubuntu": "file:../output/node-native-ubuntu",
    "@cricut/testapi-wasm": "file:../output/wasm"
  },
  "dependencies": {
    "@wasmer/wasi": "^0.12.0",
    "@wasmer/wasmfs": "^0.12.0",
    "buffer": "^5.7.1",
    "process": "^0.11.10",
    "util": "^0.11.1"
  }
}
