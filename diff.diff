+        try onMainThread(blocking: callMode) { env in
+            do {
+                result = .success(try operation(env))
+                semaphore.signal()
+            } catch {
+                result = .failure(error)
+                semaphore.signal()
+            }
+        }
+        semaphore.wait()
+        return try result!.get()
+    }
+    #endif
