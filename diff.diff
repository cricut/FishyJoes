+        )
+    );
+    static void ffi_set_foo(
+        UnownedRef obj,
+        ConsumedRef newValue,
+        OutCreatedRef exn
+    ) => catching(exn, () {
+        peekRef<AProtocolImplementation>(obj).foo = consumeRef<String>(newValue);
