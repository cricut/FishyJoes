diff --git a/integration-tests/TestAPI-bindings/c-sharp/Cricut.TestAPI.Tests/AsyncFunctionTests.cs b/integration-tests/TestAPI-bindings/c-sharp/Cricut.TestAPI.Tests/AsyncFunctionTests.cs
